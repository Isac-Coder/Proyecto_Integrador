# Puerto local (Render asigna PORT automáticamente)
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# URL de PostgreSQL/Supabase. Render puede usar DATABASE_URL directamente.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DB_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Alternativa si prefieres usar variables separadas
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Orígenes autorizados, separados por comas. Déjalo vacío durante desarrollo.
CORS_ORIGIN=http://localhost:3000
